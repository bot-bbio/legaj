{
  "manifest_version": 3,
  "name": "LeGaJ Clipper",
  "version": "1.0.0",
  "description": "Clip job listings directly into LeGaJ",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Clip Job to LeGaJ"
  },
  "background": {
    "service_worker": "background.js"
  }
}